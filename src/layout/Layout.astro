---
import '../styles/global.css';
import BottomTabBar from '../components/layout/BottomTabBar.astro';
import XPBadge from '../components/layout/XPBadge';
import pkg from '../../package.json';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, viewport-fit=cover" />
		<meta name="generator" content={Astro.generator} />
		<meta name="theme-color" content="#f7f7f5" media="(prefers-color-scheme: light)" />
		<meta name="theme-color" content="#131f24" media="(prefers-color-scheme: dark)" />
		<link rel="manifest" href="/manifest.json" />
		<link rel="apple-touch-icon" href="/icon-192.png" />
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
		<meta name="apple-mobile-web-app-title" content="A+ Study Guide" />
		<title>{title}</title>
	</head>
	<body class="min-h-screen bg-surface text-slate-900 dark:text-slate-100">
		<main class="safe-top mx-auto flex max-w-2xl flex-col gap-6 p-5 pb-24 sm:gap-8 sm:p-8 sm:pb-28">
			<slot />
		</main>
		<BottomTabBar />
		<XPBadge client:load />
		<span
			class="fixed top-2 right-2 z-30 rounded-full bg-surface-overlay px-2 py-0.5 font-mono text-[0.65rem] text-slate-400 select-none dark:text-slate-500 print:hidden"
			> 
			<a href="https://github.com/cescosgames" target="_blank" class="underline hover:opacity-50 transition">cescosgames</a> 
			|v{pkg.version}
		</span>
		<script>
			if ('serviceWorker' in navigator) {
				if (import.meta.env.PROD) {
					window.addEventListener('load', () => {
						navigator.serviceWorker.register('/sw.js');
					});
				} else {
					navigator.serviceWorker.getRegistrations().then((registrations) => {
						for (const registration of registrations) registration.unregister();
					});
				}
			}
		</script>
	</body>
</html>
