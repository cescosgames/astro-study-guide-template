---
import { changelog } from '../../lib/changelog';
---

<details class="group rounded-2xl border-2 border-border bg-surface-raised p-5 shadow-sm">
	<summary class="flex cursor-pointer list-none items-center justify-between font-display font-bold marker:content-['']">
		Changelog
		<svg
			viewBox="0 0 24 24"
			fill="none"
			stroke="currentColor"
			stroke-width="2"
			stroke-linecap="round"
			stroke-linejoin="round"
			class="h-4 w-4 shrink-0 text-slate-400 transition-transform group-open:rotate-180 dark:text-slate-500"
			aria-hidden="true"
		>
			<path d="m6 9 6 6 6-6" />
		</svg>
	</summary>
	<div class="mt-3 flex max-h-64 flex-col gap-3 overflow-y-auto pr-1">
		{
			changelog.map((entry) => (
				<div>
					<span class="text-xs font-bold text-slate-400 dark:text-slate-500">{entry.date}</span>
					<ul class="mt-0.5 list-inside list-disc text-sm text-slate-600 dark:text-slate-300">
						{entry.items.map((item) => <li>{item}</li>)}
					</ul>
				</div>
			))
		}
	</div>
</details>
