---
import { getCollection } from 'astro:content';
import Layout from '../../layout/Layout.astro';
import PageHeader from '../../layout/PageHeader.astro';
import MCQStudy from '../../components/study-kit/MCQStudy';

const entries = await getCollection('mcq');
const questions = entries.map((entry) => ({
  domain: entry.data.domain,
  topic: entry.data.topic,
  question: entry.data.question,
  choices: entry.data.choices,
  correctIndex: entry.data.correctIndex,
  explanation: entry.data.explanation,
}));
---

<Layout title="MCQ — CompTIA A+ Study Guide">
	<PageHeader title="MCQ" subtitle="Work through questions one at a time, at your own pace." />
	<MCQStudy client:load questions={questions} />
</Layout>
