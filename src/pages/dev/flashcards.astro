---
import { getCollection } from 'astro:content';
import Layout from '../../layout/Layout.astro';
import FlashcardStudy from '../../components/study-kit/FlashcardStudy';

const entries = await getCollection('flashcards');
const cards = entries.map((entry) => ({
  id: entry.id,
  domain: entry.data.domain,
  topic: entry.data.topic,
  front: entry.data.front,
  back: entry.data.back,
}));
---

<Layout title="Flashcards — CompTIA A+ Study Guide">
	<h1 class="text-2xl font-bold">Flashcards</h1>
	<FlashcardStudy client:load cert="a-plus" cards={cards} />
</Layout>
