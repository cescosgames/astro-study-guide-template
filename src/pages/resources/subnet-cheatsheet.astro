---
import Layout from '../../layout/Layout.astro';
import PageHeader from '../../layout/PageHeader.astro';

const corePattern = [
  { cidr: '/8', mask: '255.0.0.0', part: 'X', free: '. _ . _ . _', hostBits: '24 bits', hosts: '~16,000,000' },
  { cidr: '/16', mask: '255.255.0.0', part: 'X.X', free: '. _ . _', hostBits: '16 bits', hosts: '~65,000' },
  { cidr: '/24', mask: '255.255.255.0', part: 'X.X.X', free: '. _', hostBits: '8 bits', hosts: '254' },
  { cidr: '/25', mask: '255.255.255.128', part: 'X.X.X', free: '. _ (half)', hostBits: '7 bits', hosts: '126', split: true },
];

const splitRef = [
  { cidr: '/25', stolen: 1, mask: '255.255.255.128', block: '128', hosts: '126', starts: '.0 and .128' },
  { cidr: '/26', stolen: 2, mask: '255.255.255.192', block: '64', hosts: '62', starts: '.0, .64, .128, .192' },
  { cidr: '/27', stolen: 3, mask: '255.255.255.224', block: '32', hosts: '30', starts: '.0, .32, .64, .96 …' },
  { cidr: '/28', stolen: 4, mask: '255.255.255.240', block: '16', hosts: '14', starts: '.0, .16, .32, .48 …' },
  { cidr: '/29', stolen: 5, mask: '255.255.255.248', block: '8', hosts: '6', starts: '.0, .8, .16, .24 …' },
  { cidr: '/30', stolen: 6, mask: '255.255.255.252', block: '4', hosts: '2', starts: '.0, .4, .8, .12 … (point-to-point links)' },
];

const worked = [
  { q: 'Netmask', a: '255.255.255.0' },
  { q: 'Host bits', a: '32 − 24 = 8' },
  { q: 'Usable hosts', a: '2⁸ − 2 = 254' },
  { q: 'Network address', a: '192.168.10.0' },
  { q: 'Broadcast', a: '192.168.10.255' },
  { q: 'Host range', a: '192.168.10.1 → 192.168.10.254' },
];

const practice = [
  {
    addr: '10.50.0.0/8',
    rows: [
      ['Netmask', '255.0.0.0'],
      ['Usable hosts', '~16,000,000'],
      ['Network addr', '10.0.0.0'],
      ['Broadcast', '10.255.255.255'],
      ['Host range', '10.0.0.1 → 10.255.255.254'],
    ],
  },
  {
    addr: '172.20.0.0/16',
    rows: [
      ['Netmask', '255.255.0.0'],
      ['Usable hosts', '~65,000'],
      ['Network addr', '172.20.0.0'],
      ['Broadcast', '172.20.255.255'],
      ['Host range', '172.20.0.1 → 172.20.255.254'],
    ],
  },
  {
    addr: '192.168.100.0/24',
    rows: [
      ['Netmask', '255.255.255.0'],
      ['Usable hosts', '254'],
      ['Network addr', '192.168.100.0'],
      ['Broadcast', '192.168.100.255'],
      ['Host range', '192.168.100.1 → 192.168.100.254'],
    ],
  },
  {
    addr: '192.168.1.0/25',
    split: true,
    rows: [
      ['Netmask', '255.255.255.128'],
      ['Usable hosts', '126'],
      ['Network addr', '192.168.1.0'],
      ['Broadcast', '192.168.1.127'],
      ['Host range', '192.168.1.1 → 192.168.1.126'],
    ],
  },
];

const mentalSteps = [
  {
    label: 'Remainder',
    rule: 'slash ÷ 8 → quotient = full locked octets, remainder = bits stolen',
    example: '/25: 25÷8 = 3 R1 → 1 bit stolen',
  },
  {
    label: 'Stolen value',
    rule: 'read the bit value from the table above (start at 128, count right)',
    example: '1 bit → 128 | 2 bits → 128+64=192 | 3 bits → 224',
  },
  {
    label: 'Netmask',
    rule: 'last octet = sum of stolen bit values; full octets before it = 255',
    example: '/25 → 255.255.255.128',
  },
  {
    label: 'Block size',
    rule: '256 − last-octet netmask (or: value of the last stolen bit)',
    example: '256 − 128 = 128 → subnets start at .0 and .128',
  },
  {
    label: 'Network addr',
    rule: 'round the 4th octet of your address down to the nearest multiple of block size',
    example: '192.168.1.50/25 → 50 rounds to 0 → network = 192.168.1.0',
  },
  {
    label: 'Broadcast',
    rule: 'network 4th-octet + block − 1',
    example: '0 + 128 − 1 = 127 → broadcast = 192.168.1.127',
  },
  {
    label: 'Host range',
    rule: 'network+1 to broadcast−1',
    example: '192.168.1.1 → 192.168.1.126',
  },
];

const bitValues = [128, 64, 32, 16, 8, 4, 2, 1];

const blockSizeRef = [
  { mask: 128, block: 128 },
  { mask: 192, block: 64 },
  { mask: 224, block: 32 },
  { mask: 240, block: 16 },
  { mask: 248, block: 8 },
  { mask: 252, block: 4 },
  { mask: 254, block: 2 },
  { mask: 255, block: 1 },
];

const octetFromPrefix = [
  { range: '/1 – /8', octet: '1st octet' },
  { range: '/9 – /16', octet: '2nd octet' },
  { range: '/17 – /24', octet: '3rd octet' },
  { range: '/25 – /31', octet: '4th octet' },
];

// rungs: array of numbers to display. `lower`/`upper` mark the bracketing rungs.
// leadingEllipsis/trailingEllipsis show "…" where the full ladder was trimmed for space.
// upperOverflow means the "next rung" rolls past 255 into the next octet (256 isn't a real octet value).
const ladderExamples = [
  {
    cidr: '/26',
    addr: '192.168.1.77',
    mask: '255.255.255.192',
    splitOctet: '4th octet',
    maskValue: 192,
    block: 64,
    rungs: [0, 64, 128, 192],
    lower: 64,
    upper: 128,
    network: '192.168.1.64',
    broadcast: '192.168.1.127',
  },
  {
    cidr: '/25',
    addr: '10.0.0.130',
    mask: '255.255.255.128',
    splitOctet: '4th octet',
    maskValue: 128,
    block: 128,
    rungs: [0, 128],
    lower: 128,
    upper: 256,
    upperOverflow: true,
    network: '10.0.0.128',
    broadcast: '10.0.0.255',
  },
  {
    cidr: '/27',
    addr: '172.16.45.200',
    mask: '255.255.255.224',
    splitOctet: '4th octet',
    maskValue: 224,
    block: 32,
    rungs: [0, 32, 64, 96, 128, 160, 192, 224],
    lower: 192,
    upper: 224,
    network: '172.16.45.192',
    broadcast: '172.16.45.223',
  },
  {
    cidr: '/28',
    addr: '172.30.9.240',
    mask: '255.255.255.240',
    splitOctet: '4th octet',
    maskValue: 240,
    block: 16,
    rungs: [0, 16, 32, 48, 64, 80, 96, 112, 128, 144, 160, 176, 192, 208, 224, 240],
    lower: 240,
    upper: 256,
    upperOverflow: true,
    network: '172.30.9.240',
    broadcast: '172.30.9.255',
  },
  {
    cidr: '/29',
    addr: '192.168.200.14',
    mask: '255.255.255.248',
    splitOctet: '4th octet',
    maskValue: 248,
    block: 8,
    rungs: [0, 8, 16],
    lower: 8,
    upper: 16,
    trailingEllipsis: true,
    network: '192.168.200.8',
    broadcast: '192.168.200.15',
  },
  {
    cidr: '/30',
    addr: '192.168.5.201',
    mask: '255.255.255.252',
    splitOctet: '4th octet',
    maskValue: 252,
    block: 4,
    rungs: [196, 200, 204, 208],
    lower: 200,
    upper: 204,
    leadingEllipsis: true,
    trailingEllipsis: true,
    network: '192.168.5.200',
    broadcast: '192.168.5.203',
  },
  {
    cidr: '/23',
    addr: '10.20.131.55',
    mask: '255.255.254.0',
    splitOctet: '3rd octet',
    maskValue: 254,
    block: 2,
    rungs: [128, 130, 132, 134],
    lower: 130,
    upper: 132,
    leadingEllipsis: true,
    trailingEllipsis: true,
    network: '10.20.130.0',
    broadcast: '10.20.131.255',
  },
];
---

<Layout title="Subnet Cheat Sheet — CompTIA A+ Study Guide">
	<div class="print-sheet flex flex-col gap-4">
		<PageHeader badge="Reference Sheet" title="Subnet Cheat Sheet" subtitle="Networking · CIDR, netmasks, host ranges" />

		<div class="print-hide flex flex-wrap items-center gap-3">
			<button type="button" onclick="window.print()" class="btn-duo btn-duo-primary min-h-11 rounded-2xl px-5 text-sm">
				Print / Save as PDF
			</button>
			<p class="text-sm text-slate-500 dark:text-slate-400">
				In Chrome: choose "Save as PDF" as the destination. Portrait orientation recommended.
			</p>
		</div>

		<!-- CORE PATTERN -->
		<p class="mt-2 border-b-2 border-border pb-1 text-xs font-bold tracking-wide text-accent uppercase">The Core Pattern</p>
		<div class="overflow-x-auto rounded-2xl border-2 border-border bg-surface-raised shadow-sm">
			<table class="w-full border-collapse text-left text-sm">
				<thead>
					<tr class="bg-surface-overlay text-xs text-slate-500 uppercase dark:text-slate-400">
						<th class="px-3 py-2 font-display">CIDR</th>
						<th class="px-3 py-2 font-display">Netmask</th>
						<th class="px-3 py-2 font-display">Network Part</th>
						<th class="px-3 py-2 font-display">Host Bits</th>
						<th class="px-3 py-2 font-display">Usable Hosts</th>
					</tr>
				</thead>
				<tbody>
					{
						corePattern.map((row) => (
							<tr class="border-t border-border">
								<td class="px-3 py-2 font-mono font-bold text-accent">{row.cidr}</td>
								<td class="px-3 py-2 font-mono font-bold text-accent">{row.mask}</td>
								<td class="px-3 py-2">
									<span class="font-mono font-bold text-accent">{row.part}</span>{' '}
									<span class="text-xs text-slate-500 italic dark:text-slate-400">{row.free}</span>
								</td>
								<td class="px-3 py-2 text-slate-700 dark:text-slate-200">{row.hostBits}</td>
								<td class="px-3 py-2 text-slate-700 dark:text-slate-200">
									{row.hosts}
									{row.split && (
										<span class="ml-1 rounded bg-gold px-1.5 py-0.5 text-[0.65rem] font-bold tracking-wide text-slate-900 uppercase">
											split octet
										</span>
									)}
								</td>
							</tr>
						))
					}
				</tbody>
			</table>
		</div>

		<!-- MENTAL SHORTCUT -->
		<p class="mt-2 border-b-2 border-border pb-1 text-xs font-bold tracking-wide text-accent uppercase">Mental Shortcut</p>
		<div class="rounded-2xl border-2 border-accent/30 bg-accent/10 p-4 text-sm text-slate-700 dark:text-slate-200">
			<p class="font-bold text-accent">The slash ÷ 8 = how many octets are locked.</p>
			<p class="mt-1 font-mono">/8 → 1 locked octet → 255.0.0.0</p>
			<p class="font-mono">/16 → 2 locked octets → 255.255.0.0</p>
			<p class="font-mono">/24 → 3 locked octets → 255.255.255.0</p>
		</div>

		<!-- BROADCAST & HOST RANGE -->
		<p class="mt-2 border-b-2 border-border pb-1 text-xs font-bold tracking-wide text-accent uppercase">
			Broadcast &amp; Host Range — Always the Same Trick
		</p>
		<div class="overflow-x-auto rounded-2xl border-2 border-border bg-surface-raised shadow-sm">
			<table class="w-full border-collapse text-left text-sm">
				<thead>
					<tr class="bg-surface-overlay text-xs text-slate-500 uppercase dark:text-slate-400">
						<th class="px-3 py-2 font-display">Address Type</th>
						<th class="px-3 py-2 font-display">Rule</th>
					</tr>
				</thead>
				<tbody>
					<tr class="border-t border-border">
						<td class="px-3 py-2 text-slate-700 dark:text-slate-200">Network address</td>
						<td class="px-3 py-2 text-slate-700 dark:text-slate-200">
							Last free octet = <span class="font-mono font-bold text-accent">0</span>
						</td>
					</tr>
					<tr class="border-t border-border">
						<td class="px-3 py-2 text-slate-700 dark:text-slate-200">Broadcast</td>
						<td class="px-3 py-2 text-slate-700 dark:text-slate-200">
							Last free octet = <span class="font-mono font-bold text-accent">255</span>
						</td>
					</tr>
					<tr class="border-t border-border">
						<td class="px-3 py-2 text-slate-700 dark:text-slate-200">Host range</td>
						<td class="px-3 py-2 text-slate-700 dark:text-slate-200">
							Everything in between — <span class="font-mono font-bold text-accent">.1</span> to{' '}
							<span class="font-mono font-bold text-accent">.254</span> across the free octets
						</td>
					</tr>
				</tbody>
			</table>
		</div>

		<!-- 5-QUESTION FLOW -->
		<p class="mt-2 border-b-2 border-border pb-1 text-xs font-bold tracking-wide text-accent uppercase">
			The 5-Question Flow — Same Every Time
		</p>
		<ol class="flex flex-col gap-1.5 rounded-2xl border-2 border-border bg-surface-raised p-4 text-sm text-slate-700 shadow-sm dark:text-slate-200">
			<li><span class="font-mono font-bold text-accent">Netmask</span> → how many octets are locked? (slash ÷ 8)</li>
			<li><span class="font-mono font-bold text-accent">Host bits</span> → 32 minus the slash number</li>
			<li><span class="font-mono font-bold text-accent">Hosts</span> → 2^(host bits) − 2</li>
			<li><span class="font-mono font-bold text-accent">Network addr</span> → given address, last free octet = 0</li>
			<li><span class="font-mono font-bold text-accent">Broadcast</span> → last free octet = 255</li>
			<li><span class="font-mono font-bold text-accent">Range</span> → .1 to .254 across the free octets</li>
		</ol>

		<!-- SPLIT OCTETS -->
		<p class="mt-2 border-b-2 border-border pb-1 text-xs font-bold tracking-wide text-accent uppercase">
			Split Octets — What Your Mind Should Do
		</p>
		<div class="rounded-2xl border-2 border-accent/30 bg-accent/10 p-4 text-sm text-slate-700 dark:text-slate-200">
			A <strong class="text-accent">split octet</strong> happens when the slash doesn't land on a multiple of 8. Some bits of
			the last octet are "stolen" for the network part — the rest stay as host bits. The stolen bits determine the netmask,
			block size, and broadcast.
		</div>

		<p class="text-sm text-slate-500 dark:text-slate-400">Octet bit values, left to right (always this order):</p>
		<div class="overflow-x-auto rounded-2xl border-2 border-border bg-surface-raised shadow-sm">
			<table class="w-full border-collapse text-center text-sm">
				<thead>
					<tr class="bg-surface-overlay text-xs text-slate-500 uppercase dark:text-slate-400">
						{bitValues.map((_, i) => <th class="px-3 py-2 font-display">Bit {i + 1}</th>)}
					</tr>
				</thead>
				<tbody>
					<tr class="border-t border-border">
						{
							bitValues.map((v, i) => (
								<td
									class={`px-3 py-2 font-mono font-bold ${
										i < 4 ? 'bg-gold/15 text-gold-shade dark:text-gold' : 'text-slate-400 dark:text-slate-500'
									}`}
								>
									{v}
								</td>
							))
						}
					</tr>
					<tr class="border-t border-border text-xs">
						<td colspan="4" class="px-3 py-1 text-gold-shade dark:text-gold">stolen (network) ↑</td>
						<td colspan="4" class="px-3 py-1 text-slate-400 dark:text-slate-500">↑ free (host)</td>
					</tr>
				</tbody>
			</table>
		</div>
		<p class="text-xs text-slate-500 dark:text-slate-400">
			Example above shows /28 — 4 bits stolen (28 − 24 = 4). Gold = locked, grey = free.
		</p>

		<p class="text-sm font-bold text-slate-700 dark:text-slate-200">The mental path — step by step for any split CIDR:</p>
		<ol class="flex flex-col divide-y divide-border rounded-2xl border-2 border-border bg-surface-raised px-4 shadow-sm">
			{
				mentalSteps.map((step, i) => (
					<li class="flex flex-wrap items-baseline gap-x-3 gap-y-1 py-2">
						<span class="flex h-6 min-w-6 items-center justify-center rounded-full bg-accent/15 text-xs font-bold text-accent">
							{i + 1}
						</span>
						<span class="min-w-30 shrink-0 font-mono font-bold text-accent">{step.label}</span>
						<span class="text-sm text-slate-700 dark:text-slate-200">{step.rule}</span>
						<span class="text-xs text-slate-500 italic dark:text-slate-400">{step.example}</span>
					</li>
				))
			}
		</ol>

		<!-- BLOCK SIZE DIVISION TRICK -->
		<p class="mt-2 border-b-2 border-border pb-1 text-xs font-bold tracking-wide text-accent uppercase">
			Alternate Trick — Network Address by Division
		</p>
		<div class="rounded-2xl border-2 border-accent/30 bg-accent/10 p-4 text-sm text-slate-700 dark:text-slate-200">
			<p class="font-bold text-accent">Skip the rounding-down guesswork — divide it out instead.</p>
			<ol class="mt-1 flex flex-col gap-1">
				<li>1. Block size (B) = 256 − mask value in that octet</li>
				<li>2. Divide the address octet by B, ignore remainder (just count how many full block sizes fit)</li>
				<li>3. Multiply that count back by B → network octet</li>
				<li>4. Zero out everything after it</li>
			</ol>
			<p class="mt-1 font-mono text-xs italic">One-liner: (octet ÷ B, round down) × B</p>
		</div>

		<p class="mt-4 border-b-2 border-border pb-1 text-xs font-bold tracking-wide text-accent uppercase">
			Split CIDR Quick-Reference
		</p>
		<div class="overflow-x-auto rounded-2xl border-2 border-border bg-surface-raised shadow-sm">
			<table class="w-full border-collapse text-left text-sm">
				<thead>
					<tr class="bg-surface-overlay text-xs text-slate-500 uppercase dark:text-slate-400">
						<th class="px-3 py-2 font-display">CIDR</th>
						<th class="px-3 py-2 font-display">Bits stolen</th>
						<th class="px-3 py-2 font-display">Netmask</th>
						<th class="px-3 py-2 font-display">Block size</th>
						<th class="px-3 py-2 font-display">Usable hosts</th>
						<th class="px-3 py-2 font-display">Subnet starts at…</th>
					</tr>
				</thead>
				<tbody>
					{
						splitRef.map((row) => (
							<tr class="border-t border-border">
								<td class="px-3 py-2 font-mono font-bold text-accent">{row.cidr}</td>
								<td class="px-3 py-2 text-slate-700 dark:text-slate-200">{row.stolen}</td>
								<td class="px-3 py-2 font-mono font-bold text-accent">{row.mask}</td>
								<td class="px-3 py-2 font-mono font-bold text-accent">{row.block}</td>
								<td class="px-3 py-2 text-slate-700 dark:text-slate-200">{row.hosts}</td>
								<td class="px-3 py-2 text-xs text-slate-500 italic dark:text-slate-400">{row.starts}</td>
							</tr>
						))
					}
				</tbody>
			</table>
		</div>

		<!-- BLOCK-SIZE LADDER METHOD -->
		<p class="mt-4 border-b-2 border-border pb-1 text-xs font-bold tracking-wide text-accent uppercase">
			Alternate Trick — The Block-Size Ladder (Skip-Counting)
		</p>
		<div class="rounded-2xl border-2 border-accent/30 bg-accent/10 p-4 text-sm text-slate-700 dark:text-slate-200">
			<p class="font-bold text-accent">
				No division at all — list the multiples of the block size and see which two the address falls between.
			</p>
			<ol class="mt-1 flex flex-col gap-1">
				<li>1. Block size (B) = 256 − mask value in the split octet</li>
				<li>2. List multiples of B: 0, B, 2B, 3B … up through 256</li>
				<li>3. Find the two consecutive rungs the address octet falls between — the lower rung is the network address in that octet</li>
				<li>4. Next rung up − 1 = broadcast in that octet. Everything after the split octet: 0 for network, 255 for broadcast</li>
			</ol>
		</div>

		<p class="text-sm text-slate-500 dark:text-slate-400">Block size reference — mask value in the split octet → block size:</p>
		<div class="overflow-x-auto rounded-2xl border-2 border-border bg-surface-raised shadow-sm">
			<table class="w-full border-collapse text-left text-sm">
				<thead>
					<tr class="bg-surface-overlay text-xs text-slate-500 uppercase dark:text-slate-400">
						{blockSizeRef.map((row) => <th class="px-3 py-2 font-display">{row.mask}</th>)}
					</tr>
				</thead>
				<tbody>
					<tr class="border-t border-border">
						{blockSizeRef.map((row) => <td class="px-3 py-2 font-mono font-bold text-accent">{row.block}</td>)}
					</tr>
				</tbody>
			</table>
		</div>
		<p class="text-xs text-slate-500 dark:text-slate-400">Block size = 256 − mask value. E.g. mask 240 → 256 − 240 = 16.</p>

		<div class="rounded-2xl border-2 border-border bg-surface-raised p-4 text-sm shadow-sm">
			<p class="font-bold text-slate-700 dark:text-slate-200">
				Find the split octet from the CIDR prefix — don't guess it from the address:
			</p>
			<div class="mt-2 overflow-x-auto">
				<table class="w-full border-collapse text-left text-sm">
					<thead>
						<tr class="text-xs text-slate-500 uppercase dark:text-slate-400">
							<th class="px-3 py-1 font-display">Prefix range</th>
							<th class="px-3 py-1 font-display">Split octet</th>
						</tr>
					</thead>
					<tbody>
						{
							octetFromPrefix.map((row) => (
								<tr class="border-t border-border">
									<td class="px-3 py-1 font-mono font-bold text-accent">{row.range}</td>
									<td class="px-3 py-1 text-slate-700 dark:text-slate-200">{row.octet}</td>
								</tr>
							))
						}
					</tbody>
				</table>
			</div>
			<p class="mt-2 text-xs text-slate-500 italic dark:text-slate-400">
				e.g. /23 → 255.255.254.0 → the mask value isn't 255 until the 3rd octet, so the split octet is the 3rd — read it
				straight off the prefix, not off which number in the address "looks splittable."
			</p>
		</div>

		<p class="mt-2 border-b-2 border-border pb-1 text-xs font-bold tracking-wide text-accent uppercase">
			Ladder Worked Examples
		</p>
		<div class="grid gap-3 sm:grid-cols-2">
			{
				ladderExamples.map((ex) => (
					<div class="rounded-2xl border-2 border-border bg-surface-raised p-4 shadow-sm">
						<p class="mb-1 flex flex-wrap items-baseline gap-x-2">
							<span class="font-mono text-base font-bold text-accent">
								{ex.addr}
								{ex.cidr}
							</span>
							<span class="rounded bg-gold px-1.5 py-0.5 align-middle text-[0.65rem] font-bold tracking-wide text-slate-900 uppercase">
								{ex.splitOctet}
							</span>
						</p>
						<p class="text-xs text-slate-500 dark:text-slate-400">
							Mask <span class="font-mono text-slate-700 dark:text-slate-200">{ex.mask}</span> · split-octet value{' '}
							<span class="font-mono font-bold text-accent">{ex.maskValue}</span> · block ={' '}
							<span class="font-mono font-bold text-accent">
								256 − {ex.maskValue} = {ex.block}
							</span>
						</p>

						<p class="mt-2 text-xs font-bold tracking-wide text-slate-500 uppercase dark:text-slate-400">Ladder</p>
						<div class="mt-1 flex flex-wrap items-center gap-1 font-mono text-xs">
							{ex.leadingEllipsis && <span class="text-slate-400 dark:text-slate-500">…</span>}
							{
								ex.rungs.map((v) => (
									<span
										class={`rounded px-1.5 py-0.5 ${
											v === ex.lower
												? 'bg-accent/20 font-bold text-accent'
												: v === ex.upper
													? 'bg-gold/20 font-bold text-gold-shade dark:text-gold'
													: 'text-slate-500 dark:text-slate-400'
										}`}
									>
										{v}
									</span>
								))
							}
							{ex.trailingEllipsis && <span class="text-slate-400 dark:text-slate-500">…</span>}
							{ex.upperOverflow && (
								<span class="rounded bg-gold/20 px-1.5 py-0.5 font-bold text-gold-shade dark:text-gold">
									256 (rolls to next octet)
								</span>
							)}
						</div>
						<p class="mt-1 text-xs text-slate-500 dark:text-slate-400">
							<span class="font-mono font-bold text-accent">{ex.addr.split('.').at(ex.splitOctet.startsWith('3') ? 2 : 3)}</span>{' '}
							falls between <span class="font-mono font-bold text-accent">{ex.lower}</span> and{' '}
							<span class="font-mono font-bold text-gold-shade dark:text-gold">{ex.upper}</span> → round down to{' '}
							{ex.lower}
						</p>

						<table class="mt-2 w-full border-collapse text-xs">
							<tbody>
								<tr class="border-t border-border">
									<td class="w-[42%] py-1 pr-2 text-slate-500 uppercase dark:text-slate-400">Network addr</td>
									<td class="py-1 font-mono font-bold text-accent">{ex.network}</td>
								</tr>
								<tr class="border-t border-border">
									<td class="py-1 pr-2 text-slate-500 uppercase dark:text-slate-400">Broadcast</td>
									<td class="py-1 font-mono font-bold text-gold-shade dark:text-gold">{ex.broadcast}</td>
								</tr>
							</tbody>
						</table>
					</div>
				))
			}
		</div>

		<div class="rounded-2xl border-2 border-danger/30 bg-danger/10 p-4 text-sm text-slate-700 dark:text-slate-200">
			<p class="font-bold text-danger">Common mistakes</p>
			<ul class="mt-1 flex flex-col gap-1 list-disc pl-4">
				<li>Don't confuse the <strong>mask value</strong> (e.g. 224) with the <strong>computed network/broadcast octet</strong> (e.g. 192) — the mask value is never the answer by itself.</li>
				<li>Watch for off-by-one errors converting CIDR → mask: <span class="font-mono">/23 = 254</span>, not 248 — count the stolen bits from the prefix, don't eyeball it.</li>
				<li>Always sanity-check a candidate network address by confirming it's actually divisible by the block size (e.g. 192 ÷ 32 = 6 exactly — no remainder means it's a valid rung on the ladder).</li>
			</ul>
		</div>

		<!-- WORKED EXAMPLE -->
		<p class="mt-2 border-b-2 border-border pb-1 text-xs font-bold tracking-wide text-accent uppercase">
			Worked Example — 192.168.10.0/24
		</p>
		<div class="overflow-x-auto rounded-2xl border-2 border-border bg-surface-raised shadow-sm">
			<table class="w-full border-collapse text-left text-sm">
				<thead>
					<tr class="bg-surface-overlay text-xs text-slate-500 uppercase dark:text-slate-400">
						<th class="px-3 py-2 font-display">Question</th>
						<th class="px-3 py-2 font-display">Answer</th>
					</tr>
				</thead>
				<tbody>
					{
						worked.map((row) => (
							<tr class="border-t border-border">
								<td class="px-3 py-2 text-slate-700 dark:text-slate-200">{row.q}</td>
								<td class="px-3 py-2 font-mono font-bold text-accent">{row.a}</td>
							</tr>
						))
					}
				</tbody>
			</table>
		</div>

		<!-- PRACTICE PROBLEMS -->
		<p class="mt-2 border-b-2 border-border pb-1 text-xs font-bold tracking-wide text-accent uppercase">Practice Problems</p>
		<div class="grid gap-3 sm:grid-cols-2">
			{
				practice.map((card) => (
					<div class="rounded-2xl border-2 border-border bg-surface-raised p-4 shadow-sm">
						<p class="mb-2 font-mono text-base font-bold text-accent">
							{card.addr}
							{card.split && (
								<span class="ml-1 rounded bg-gold px-1.5 py-0.5 align-middle text-[0.65rem] font-bold tracking-wide text-slate-900 uppercase">
									split octet
								</span>
							)}
						</p>
						<table class="w-full border-collapse text-xs">
							<tbody>
								{card.rows.map(([label, value]) => (
									<tr class="border-t border-border first:border-t-0">
										<td class="w-[42%] py-1 pr-2 text-slate-500 uppercase dark:text-slate-400">{label}</td>
										<td class="py-1 font-mono text-slate-700 dark:text-slate-200">{value}</td>
									</tr>
								))}
							</tbody>
						</table>
					</div>
				))
			}
		</div>
	</div>
</Layout>
