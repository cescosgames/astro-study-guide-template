---
import Layout from '../../layout/Layout.astro';
import PageHeader from '../../layout/PageHeader.astro';
import { portSections as sections, type PortRow } from '../../lib/ports';

const tagClass: Record<PortRow['tag'], string> = {
  tcp: 'bg-accent/15 text-accent',
  udp: 'bg-gold/15 text-gold-shade dark:text-gold',
  both: 'bg-slate-500/15 text-slate-600 dark:text-slate-300',
};
const tagLabel: Record<PortRow['tag'], string> = { tcp: 'TCP', udp: 'UDP', both: 'TCP/UDP' };
---

<Layout title="Common Ports & Protocols — CompTIA A+ Study Guide">
	<div class="print-sheet flex flex-col gap-4">
		<PageHeader badge="Reference Sheet" title="Common Ports & Protocols" subtitle="A+ Exam · Networking fundamentals" />

		<div class="print-hide flex flex-wrap items-center gap-3">
			<button type="button" onclick="window.print()" class="btn-duo btn-duo-primary min-h-11 rounded-2xl px-5 text-sm">
				Print / Save as PDF
			</button>
			<p class="text-sm text-slate-500 dark:text-slate-400">
				In Chrome: choose "Save as PDF" as the destination. Landscape orientation recommended.
			</p>
		</div>

		{
			sections.map((section) => (
				<div>
					<p class="mt-2 border-b-2 border-border pb-1 text-xs font-bold tracking-wide text-accent uppercase">
						{section.heading}
					</p>
					<div class="mt-2 overflow-x-auto rounded-2xl border-2 border-border bg-surface-raised shadow-sm">
						<table class="w-full border-collapse text-left text-sm">
							<thead>
								<tr class="bg-surface-overlay text-xs text-slate-500 uppercase dark:text-slate-400">
									<th class="px-3 py-2 font-display">Port</th>
									<th class="px-3 py-2 font-display">Protocol</th>
									<th class="px-3 py-2 font-display">Service</th>
									<th class="px-3 py-2 font-display">Memory Hook</th>
								</tr>
							</thead>
							<tbody>
								{section.rows.map((row) => (
									<tr class="border-t border-border">
										<td class="px-3 py-2 font-mono font-bold whitespace-nowrap text-accent">{row.port}</td>
										<td class="px-3 py-2">
											<span class={`w-fit rounded-lg px-2 py-0.5 text-xs font-bold ${tagClass[row.tag]}`}>
												{tagLabel[row.tag]}
											</span>
										</td>
										<td class="px-3 py-2 text-slate-700 dark:text-slate-200">{row.service}</td>
										<td class="px-3 py-2 text-xs text-slate-500 italic dark:text-slate-400">{row.hook}</td>
									</tr>
								))}
							</tbody>
						</table>
					</div>
				</div>
			))
		}
	</div>
</Layout>
