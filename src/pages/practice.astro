---
import Layout from '../layout/Layout.astro';
import PageHeader from '../layout/PageHeader.astro';

const modes = [
  {
    href: '/dev/subnet-calculator',
    label: 'Subnet Calculator',
    description: 'Procedurally generated CIDR/subnet math drills.',
  },
  {
    href: '/dev/ipv6-shrinker',
    label: 'IPv6 Shrinker',
    description: 'Practice compressing and expanding IPv6 addresses.',
  },
  {
    href: '/dev/cli-practice',
    label: 'CLI Practice',
    description: 'Type the exact Windows/Linux command for the task.',
  },
  {
    href: '/dev/port-match',
    label: 'Port Match',
    description: 'Tap to pair common ports with their services.',
  },
];
---

<Layout title="Practice — CompTIA A+ Study Guide">
	<PageHeader title="Practice" subtitle="Hands-on drills for the math-heavy topics." />
	<div class="grid gap-4 sm:grid-cols-2">
		{
			modes.map((mode) => (
				<a
					href={mode.href}
					class="flex flex-col gap-1 rounded-2xl border-2 border-border bg-surface-raised p-5 shadow-sm transition-transform hover:-translate-y-0.5 hover:border-accent active:translate-y-0"
				>
					<span class="font-display font-bold">{mode.label}</span>
					<span class="text-sm text-slate-500 dark:text-slate-400">{mode.description}</span>
				</a>
			))
		}
	</div>
</Layout>
