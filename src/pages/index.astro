---
import Layout from '../layout/Layout.astro';

const demos = [
  { href: '/dev/flashcards', label: 'Flashcard', description: 'Flip card with known/learning tracking' },
  { href: '/dev/mcq', label: 'MCQ Deck', description: 'Multiple-choice question flow with scoring' },
  { href: '/dev/rapid-fire', label: 'Rapid Fire', description: 'Timed, shuffled quiz across all questions' },
  { href: '/dev/progress', label: 'Progress Tracker', description: 'Per-section checkbox progress, localStorage-backed' },
  { href: '/dev/subnet-calculator', label: 'Subnet Calculator', description: 'Procedurally generated CIDR/subnet drills' },
  { href: '/dev/ipv6-shrinker', label: 'IPv6 Shrinker', description: 'Procedurally generated IPv6 compression drills' },
];
---

<Layout title="CompTIA A+ Study Guide — Phase 1 stubs">
	<h1 class="text-2xl font-bold">study-kit component stubs</h1>
	<p class="text-slate-600 dark:text-slate-400">
		Phase 1 skeleton — each component below is wired with placeholder data. Real content comes in
		Phase 2.
	</p>
	<div class="grid gap-4 sm:grid-cols-2">
		{demos.map((demo) => (
			<a
				href={demo.href}
				class="flex flex-col gap-1 rounded-xl border border-slate-300 bg-white p-5 transition-colors hover:border-slate-400 dark:border-slate-700 dark:bg-slate-900 dark:hover:border-slate-600"
			>
				<span class="font-semibold">{demo.label}</span>
				<span class="text-sm text-slate-500 dark:text-slate-400">{demo.description}</span>
			</a>
		))}
	</div>
</Layout>
