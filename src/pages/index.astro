---
import Layout from "../layout/Layout.astro";
import PageHeader from "../layout/PageHeader.astro";
import ProgressTracker from "../components/study-kit/ProgressTracker";
import LevelRecap from "../components/layout/LevelRecap";
import ChangelogCard from "../components/layout/ChangelogCard.astro";

const modes = [
	{
		href: "/dev/flashcards",
		label: "Flashcards",
		description: "Flip through cards, mark what you know.",
		icon: "M4 6.5A1.5 1.5 0 0 1 5.5 5h9A1.5 1.5 0 0 1 16 6.5v11A1.5 1.5 0 0 1 14.5 19h-9A1.5 1.5 0 0 1 4 17.5v-11ZM8 3h9.5A1.5 1.5 0 0 1 19 4.5v11",
		chip: "accent",
	},
	{
		href: "/quiz",
		label: "Quiz",
		description: "MCQ deck or a timed rapid-fire round.",
		icon: "M12 3a9 9 0 1 0 0 18 9 9 0 0 0 0-18ZM9.5 9a2.5 2.5 0 1 1 3.5 2.3c-.7.3-1 .9-1 1.7v.5M12 17h.01",
		chip: "gold",
	},
	{
		href: "/practice",
		label: "Practice",
		description: "Subnetting and IPv6 drills.",
		icon: "M14.5 3.5 20.5 9.5 9.5 20.5l-6-1 1-6L14.5 3.5Z M13 5l6 6",
		chip: "accent",
	},
	{
		href: "/resources",
		label: "Resources",
		description: "Printable cheat sheets and CLI practice.",
		icon: "M6 4h9l3 3v13a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V5a1 1 0 0 1 1-1Z M14 4v4h4",
		chip: "gold",
	},
];
---

<Layout title="CompTIA A+ Study Guide">
	<PageHeader
		title="CompTIA A+ Study Guide"
		subtitle="Pick up where you left off."
	/>

	<!-- progress tracker, not active curently -->
	<!-- <div
		class="rounded-2xl border-2 border-border bg-surface-raised p-5 shadow-sm"
	>
		<ProgressTracker
			client:load
			cert="a-plus"
			section="stub-section"
			itemIds={["item-1", "item-2", "item-3"]}
		/>
	</div> -->

	<LevelRecap client:load />

	<div class="grid gap-4 sm:grid-cols-2">
		{
			modes.map((mode) => (
				<a
					href={mode.href}
					class="flex flex-col gap-3 rounded-2xl border-2 border-border bg-surface-raised p-5 shadow-sm transition-transform hover:-translate-y-0.5 hover:border-accent active:translate-y-0"
				>
					<span
						class={`flex h-11 w-11 items-center justify-center rounded-full ${
							mode.chip === "gold"
								? "bg-gold/15 text-gold-shade dark:text-gold"
								: "bg-accent/15 text-accent"
						}`}
					>
						<svg
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="1.75"
							stroke-linecap="round"
							stroke-linejoin="round"
							class="h-6 w-6"
							aria-hidden="true"
						>
							<path d={mode.icon} />
						</svg>
					</span>
					<span class="font-display font-bold">{mode.label}</span>
					<span class="text-sm text-slate-500 dark:text-slate-400">
						{mode.description}
					</span>
				</a>
			))
		}
		<ChangelogCard />
	</div>
</Layout>
